generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  sales_rep
}

enum OrderItemType {
  product
  shipping
  payment
  other
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(sales_rep)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customerAssignmentsAsSalesRep CustomerAssignment[] @relation("SalesRepAssignments")
  customerAssignmentsAsAdmin    CustomerAssignment[] @relation("AssignedByAdmin")
  importRunsTriggered           ImportRun[]          @relation("ImportTriggeredBy")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments CustomerAssignment[]
  orders      Order[]
}

model CatalogCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalTopProduct {
  id           Int      @id @default(autoincrement())
  sku          String?  @unique
  name         String   @unique
  categoryName String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerAssignment {
  id         Int       @id @default(autoincrement())
  customerId Int
  salesRepId Int
  assignedById Int?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesRep   User     @relation("SalesRepAssignments", fields: [salesRepId], references: [id], onDelete: Restrict)
  assignedBy User?    @relation("AssignedByAdmin", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([customerId, endedAt])
  @@index([salesRepId, endedAt])
}

model Order {
  id         Int      @id @default(autoincrement())
  orderId    String   @unique
  customerId Int
  status     String
  importedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]

  @@index([customerId, importedAt])
}

model OrderItem {
  id             Int           @id @default(autoincrement())
  orderDbId      Int
  lineType       OrderItemType @default(product)
  sku            String?
  name           String?
  category       String?
  quantity       Decimal       @db.Decimal(12, 3)
  unitPriceNetCzk Decimal      @db.Decimal(14, 2)
  lineNetCzk     Decimal       @db.Decimal(14, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderDbId], references: [id], onDelete: Cascade)

  @@index([orderDbId])
  @@index([lineType])
}

model ImportRun {
  id            Int      @id @default(autoincrement())
  sourceName    String?
  triggeredById Int?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  totalRecords  Int      @default(0)
  createdOrders Int      @default(0)
  updatedOrders Int      @default(0)
  errorRecords  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  triggeredBy User?            @relation("ImportTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  errors      ImportRunError[]

  @@index([startedAt])
}

model ImportRunError {
  id             Int      @id @default(autoincrement())
  importRunId    Int
  recordIndex    Int
  orderIdValue   String?
  customerIdValue String?
  message        String
  rawRecord      Json?
  createdAt      DateTime @default(now())

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId, recordIndex])
}
