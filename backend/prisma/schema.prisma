generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  sales_rep
}

enum OrderItemType {
  product
  shipping
  payment
  other
}

enum CustomerGroupScope {
  global
  private
}

enum CustomerGroupFilterType {
  active_orders_last_months
}

enum RecommendationRuleScope {
  global
  private
}

enum RecommendationTargetType {
  category
  top_product
}

enum TaskPriority {
  low
  medium
  high
}

enum CustomerTaskStatus {
  open
  done
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(sales_rep)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customerAssignmentsAsSalesRep CustomerAssignment[] @relation("SalesRepAssignments")
  customerAssignmentsAsAdmin    CustomerAssignment[] @relation("AssignedByAdmin")
  importRunsTriggered           ImportRun[]          @relation("ImportTriggeredBy")
  customerGroupsOwned           CustomerGroup[]      @relation("GroupOwner")
  recommendationRulesOwned      RecommendationRule[] @relation("RuleOwner")
  customerNotesAuthored         CustomerNote[]       @relation("CustomerNoteAuthor")
  customerTasksOwned            CustomerTask[]       @relation("CustomerTaskOwner")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments CustomerAssignment[]
  orders      Order[]
  notes       CustomerNote[]
  tasks       CustomerTask[]
}

model CatalogCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalTopProduct {
  id           Int      @id @default(autoincrement())
  sku          String?  @unique
  name         String   @unique
  categoryName String?
  unitPriceNetCzk Decimal? @db.Decimal(14, 2)
  stockQuantity Int?
  historicalSalesQty Int?
  incomingFromSupplierQty Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerGroup {
  id         Int                     @id @default(autoincrement())
  name       String
  scope      CustomerGroupScope
  ownerUserId Int?
  filterType CustomerGroupFilterType @default(active_orders_last_months)
  monthsBack Int                     @default(12)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  owner             User?                @relation("GroupOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  rulesAsTarget     RecommendationRule[] @relation("RuleGroup")
  rulesAsComparison RecommendationRule[] @relation("RuleComparisonGroup")

  @@index([scope, ownerUserId])
  @@index([name])
}

model RecommendationRule {
  id                Int                      @id @default(autoincrement())
  name              String
  scope             RecommendationRuleScope
  ownerUserId       Int?
  groupId           Int
  comparisonGroupId Int?
  targetType        RecommendationTargetType
  targetValue       String
  minPenetrationPct Decimal                  @db.Decimal(5, 2)
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  owner           User?         @relation("RuleOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  group           CustomerGroup @relation("RuleGroup", fields: [groupId], references: [id], onDelete: Restrict)
  comparisonGroup CustomerGroup? @relation("RuleComparisonGroup", fields: [comparisonGroupId], references: [id], onDelete: SetNull)

  @@index([scope, ownerUserId, isActive])
  @@index([groupId])
  @@index([comparisonGroupId])
}

model CustomerNote {
  id           Int      @id @default(autoincrement())
  customerId   Int
  authorUserId Int
  text         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author   User     @relation("CustomerNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([customerId, createdAt])
  @@index([authorUserId, createdAt])
}

model CustomerTask {
  id          Int                @id @default(autoincrement())
  customerId  Int
  ownerUserId Int
  description String
  dueDate     DateTime
  priority    TaskPriority       @default(medium)
  status      CustomerTaskStatus @default(open)
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner    User     @relation("CustomerTaskOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@index([customerId, dueDate])
  @@index([ownerUserId, dueDate])
  @@index([status, dueDate])
}

model CustomerAssignment {
  id         Int       @id @default(autoincrement())
  customerId Int
  salesRepId Int
  assignedById Int?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesRep   User     @relation("SalesRepAssignments", fields: [salesRepId], references: [id], onDelete: Restrict)
  assignedBy User?    @relation("AssignedByAdmin", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([customerId, endedAt])
  @@index([salesRepId, endedAt])
}

model Order {
  id         Int      @id @default(autoincrement())
  orderId    String   @unique
  customerId Int
  status     String
  importedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]

  @@index([customerId, importedAt])
}

model OrderItem {
  id             Int           @id @default(autoincrement())
  orderDbId      Int
  lineType       OrderItemType @default(product)
  sku            String?
  name           String?
  category       String?
  quantity       Decimal       @db.Decimal(12, 3)
  unitPriceNetCzk Decimal      @db.Decimal(14, 2)
  lineNetCzk     Decimal       @db.Decimal(14, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderDbId], references: [id], onDelete: Cascade)

  @@index([orderDbId])
  @@index([lineType])
}

model ImportRun {
  id            Int      @id @default(autoincrement())
  sourceName    String?
  triggeredById Int?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  totalRecords  Int      @default(0)
  createdOrders Int      @default(0)
  updatedOrders Int      @default(0)
  errorRecords  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  triggeredBy User?            @relation("ImportTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  errors      ImportRunError[]

  @@index([startedAt])
}

model ImportRunError {
  id             Int      @id @default(autoincrement())
  importRunId    Int
  recordIndex    Int
  orderIdValue   String?
  customerIdValue String?
  message        String
  rawRecord      Json?
  createdAt      DateTime @default(now())

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId, recordIndex])
}
